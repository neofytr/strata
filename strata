#!/bin/bash

# neobuild bootstrap — compiles your build file with the neobuild library

clean_mode=false

while getopts "c" opt; do
  case ${opt} in
    c )
      clean_mode=true
      ;;
    \? )
      echo "Usage: $0 [-c] [<source_file.c>]"
      echo "  -c: clean all compiled objects and binaries"
      exit 1
      ;;
  esac
done

shift $((OPTIND -1))

if [ "$clean_mode" = true ]; then
    echo "cleaning all compiled objects and binaries..."
    rm -f buildsysdep/*.o
    echo "clean complete."
    exit 0
fi

if [ "$#" -ne 1 ]; then
    echo "Usage: $0 [-c] [<source_file.c>]"
    echo "  -c: clean all compiled objects and binaries"
    exit 1
fi

SOURCE_FILE="$1"
OUTPUT_FILE="${SOURCE_FILE%.c}"

if command -v gcc &>/dev/null; then
    CC=gcc
elif command -v clang &>/dev/null; then
    CC=clang
else
    echo "error: no gcc or clang compiler found."
    exit 1
fi

echo "using compiler: $CC"

SRCS="neo_core neo_arena neo_platform neo_command neo_deps neo_compile neo_graph neo_toolchain neo_detect neo_install neo_test_runner neo_config"

for src in $SRCS; do
    SRC_FILE="buildsysdep/${src}.c"
    OBJ_FILE="buildsysdep/${src}.o"
    if [ ! -f "$OBJ_FILE" ] || [ "$SRC_FILE" -nt "$OBJ_FILE" ] || [ "buildsysdep/neo_internal.h" -nt "$OBJ_FILE" ] || [ "buildsysdep/neobuild.h" -nt "$OBJ_FILE" ]; then
        echo "compiling ${src}.o"
        $CC -c "$SRC_FILE" -o "$OBJ_FILE" -O3 -march=native
        if [ $? -ne 0 ]; then
            echo "failed to compile ${src}.o"
            exit 1
        fi
    fi
done

# Then link user's file with all .o files
ALL_OBJS=""
for src in $SRCS; do
    ALL_OBJS="$ALL_OBJS buildsysdep/${src}.o"
done

echo "compiling $SOURCE_FILE"
$CC "$SOURCE_FILE" $ALL_OBJS -o "$OUTPUT_FILE" -lm -O3 -march=native

if [ $? -eq 0 ]; then
    echo "compilation successful: $OUTPUT_FILE"
else
    echo "compilation failed."
    exit 1
fi
